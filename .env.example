# ==================== EduManus 教学智能体协作系统 - 环境变量配置 ====================
# 复制此文件为 .env 并根据实际情况修改配置
# cp .env.example .env

# ==================== LLM 模型配置 ====================
# 以下为 api/config.yaml 中 llm_config 的环境变量覆盖（可选）
# 也可以直接在 api/config.yaml 中配置

# OpenAI 兼容接口配置（必填其一）
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-api-key-here
# LLM_MODEL_NAME=gpt-4o

# DeepSeek 配置示例
# LLM_BASE_URL=https://api.deepseek.com/
# LLM_API_KEY=sk-your-deepseek-key-here
# LLM_MODEL_NAME=deepseek-reasoner

# Anthropic Claude 配置示例
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL_NAME=claude-3-5-sonnet-20241022

# ==================== 数据库配置 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edumanus

# ==================== 对象存储配置（文件上传） ====================
# 腾讯云 COS 配置（用于学生作业、教学资料等文件存储）
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here
COS_BUCKET=your_cos_bucket_here
COS_REGION=ap-beijing

# ==================== 服务端口配置 ====================
# Nginx 对外暴露端口（默认 8088）
NGINX_PORT=8088

# ==================== 沙箱配置 ====================
# 沙箱镜像名称（与 docker-compose.yml 中一致）
SANDBOX_IMAGE=edumanus-sandbox
# 沙箱超时时间（秒）
SANDBOX_TIMEOUT=300

# ==================== 搜索引擎配置（可选） ====================
# Google Search API（用于教学资源搜索）
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Bing Search API
# BING_API_KEY=your_bing_api_key_here

# ==================== 其他可选配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Redis 配置（通常无需修改，使用内部网络连接）
# REDIS_URL=redis://edumanus-redis:6379/0

# PostgreSQL 连接 URL（通常无需修改，使用内部网络连接）
# DATABASE_URL=postgresql://postgres:postgres@edumanus-postgres:5432/edumanus